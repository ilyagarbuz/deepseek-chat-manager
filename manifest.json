{
  "manifest_version": 3,
  "name": "DeepSeek Chat Manager",
  "version": "1.0.0",
  "description": "Extension for organizing DeepSeek chats into folders",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://chat.deepseek.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "DeepSeek Chat Manager"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["https://chat.deepseek.com/*"]
    }
  ]
}
